{
  "name": "check-in-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenvx run -- tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "dotenvx run -- node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test",
    "db:link": "supabase link",
    "db:push": "supabase db push --linked",
    "db:seed": "supabase db query --linked --file supabase/seed.sql",
    "db:push:seed": "pnpm run db:push && pnpm run db:seed",
    "db:reset": "supabase db reset --local"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.45.1",
    "@hono/node-server": "^1.18.2",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.1.0",
    "@hono/zod-validator": "^0.7.5",
    "@supabase/supabase-js": "^2.86.0",
    "hono": "^4.12.9",
    "pino": "^10.1.0",
    "rate-limiter-flexible": "^8.3.0",
    "undici": "^7.16.0",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.2",
    "supabase": "^2.105.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.18.1 <23"
  }
}
